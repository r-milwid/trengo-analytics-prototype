{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "prototype",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["-e", "const h=require('http'),fs=require('fs'),p=require('path'),root=process.cwd(),port=process.env.PORT||3000;const mime={'html':'text/html','js':'application/javascript','css':'text/css','json':'application/json','png':'image/png','svg':'image/svg+xml','ico':'image/x-icon'};h.createServer((q,r)=>{const url=q.url.split('?')[0];const f=p.join(root,url==='/'?'index.html':url);fs.stat(f,(err,s)=>{if(err||!s.isFile()){r.writeHead(404);r.end('Not found');return;}const ext=p.extname(f).slice(1);r.writeHead(200,{'Content-Type':mime[ext]||'application/octet-stream'});const st=fs.createReadStream(f);st.on('error',()=>r.end());st.pipe(r);});}).listen(port,()=>console.log('Server on '+port));"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "guide-dev",
      "runtimeExecutable": "/Users/m.wammes/.nvm/versions/node/v24.14.0/bin/node",
      "runtimeArgs": ["-e", "const h=require('http'),fs=require('fs'),p=require('path'),root='/Users/m.wammes/Documents/GitHub/prototype-guide/public';const mime={'html':'text/html','js':'application/javascript','css':'text/css','json':'application/json','png':'image/png','svg':'image/svg+xml','ico':'image/x-icon'};h.createServer((q,r)=>{const url=q.url.split('?')[0];const f=p.join(root,url==='/'?'index.html':url);fs.stat(f,(err,s)=>{if(err||!s.isFile()){r.writeHead(404);r.end('Not found');return;}const ext=p.extname(f).slice(1);r.writeHead(200,{'Content-Type':mime[ext]||'application/octet-stream'});const st=fs.createReadStream(f);st.on('error',()=>r.end());st.pipe(r);});}).listen(3000,()=>console.log('Guide server on 3000'));"],
      "port": 3000
    }
  ]
}
